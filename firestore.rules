rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read access to offers collection
    // Public read for website config
    match /websiteConfig/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Public read for products
    match /products/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Public read for blogs
    match /blogs/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Public read for offers
    match /offers/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Public read for shop settings (excluding admin whitelist)
    match /config/portal_settings {
      allow read: if true;
    }
    
    // Public read for AI settings
    match /config/ai_settings {
      allow read: if true;
    }
    
    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
