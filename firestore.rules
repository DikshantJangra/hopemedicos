rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'hope.medicos@gmail.com' ||
        request.auth.token.phone_number == '+919812080390'
      );
    }

    // PUBLIC READ COLLECTIONS (for main website & app)
    match /products/{document=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /medicines/{document=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /categories/{document=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /blogs/{document=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /offers/{document=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /productOffers/{document=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /storeStatus/{document=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /websiteConfig/{document=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /websiteData/{document=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /website/{document=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /config/{document=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /initiatives/{document=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // PUBLIC WRITE COLLECTIONS (for website functionality)
    match /hooks/{document=**} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /contactForms/{document=**} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /newsletter/{document=**} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /analytics/{document=**} {
      allow read: if isAdmin();
      allow create: if true;
    }

    // USER COLLECTIONS
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    match /orders/{oId} {
      allow read: if request.auth != null;
      allow write, delete: if isAdmin();
    }

    // FALLBACK - deny everything else
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
