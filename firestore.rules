rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read access to offers collection
    match /offers/{offerId} {
      allow read: if true;
      allow write: if false; // Only allow writes through admin SDK or Firebase Console
    }
    
    // Allow public read access to medicines collection
    match /medicines/{medicineId} {
      allow read: if true;
      allow write: if false; // Only allow writes through admin SDK or Firebase Console
    }
    
    // Allow public read access to initiatives collection
    match /initiatives/{initiativeId} {
      allow read: if true;
      allow write: if false; // Only allow writes through admin SDK or Firebase Console
    }
    
    // Allow public read access to products collection
    match /products/{productId} {
      allow read: if true;
      allow write: if false; // Only allow writes through admin SDK or Firebase Console
    }
    
    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
